  }
  
  forsec CellRef.apical {
  }
  
  forsec CellRef.axonal {
    ena = 50
    ek = -90
    vshifth_NaTg = 10
    slopem_NaTg = 9
    gNaTgbar_NaTg = 0.19617714561373989
    gNap_Et2bar_Nap_Et2 = 0.00019745404132448345
    gK_Pstbar_K_Pst = 0.56409918103405565
    gK_Tstbar_K_Tst = 0.13981805216037169
    gSKv3_1bar_SKv3_1 = 0.07228545382334306
    gCa_HVAbar_Ca_HVA2 = 0.00083305959896562876
    gCa_LVAstbar_Ca_LVAst = 0.0010963840895670083
    gSK_E2bar_SK_E2 = 0.0042228171954035686
    decay_CaDynamics_DC0 = 298.03518655500403
    gamma_CaDynamics_DC0 = 0.0097245047144724414
    gIhbar_Ih = 0.00015436629928111483
  }
  
  forsec CellRef.basal {
  }
  
  forsec CellRef.somatic {
    ena = 50
    ek = -90
    vshiftm_NaTg = 13
    vshifth_NaTg = 15
    slopem_NaTg = 7
    gNaTgbar_NaTg = 0.0063114715926466669
    gK_Pstbar_K_Pst = 2.4999999292951713e-10
    gK_Tstbar_K_Tst = 0.0058712992357145277
